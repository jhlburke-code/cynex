---
// Magic-link callback. Supabase redirects the user here with either
//   PKCE:        ?code=<auth_code>
//   Implicit:    #access_token=...&refresh_token=...
// Server can't read hash fragments, so this is HTML+JS that
// forwards tokens to /api/login/finish, which sets cookies,
// then we redirect to /me.
import Layout from '../../../layouts/Layout.astro';

const url = new URL(Astro.request.url);
const next = url.searchParams.get('next') ?? '/me';
---
<Layout title="Signing you in…">
  <section class="container" style="max-width: 480px; text-align: center;">
    <h1>Signing you in…</h1>
    <p class="muted">If this doesn't redirect, <a href="/login">request a new link</a>.</p>
    <pre id="cynex-callback-debug" style="text-align:left;font-size:11px;margin-top:24px;color:#888;white-space:pre-wrap;word-break:break-all;"></pre>
  </section>

  <script is:inline define:vars={{ next }}>
    (async () => {
      const log = (m) => {
        const el = document.getElementById('cynex-callback-debug');
        if (el) el.textContent += m + '\n';
        try { console.log('[cynex]', m); } catch {}
      };

      try {
        log('1. callback page loaded');
        log('2. URL: ' + window.location.href);

        const errorDescription = new URL(window.location.href).searchParams.get('error_description') || '';
        if (errorDescription) {
          log('3a. error_description=' + errorDescription);
          window.location.replace('/login?error=' + encodeURIComponent(errorDescription));
          return;
        }

        const params = new URLSearchParams(window.location.hash.slice(1));
        const access_token = params.get('access_token') || '';
        const refresh_token = params.get('refresh_token') || '';
        const code = new URL(window.location.href).searchParams.get('code') || '';

        log('3b. access_token=' + (access_token ? access_token.slice(0, 12) + '…' : '(empty)'));
        log('3c. refresh_token=' + (refresh_token ? refresh_token.slice(0, 12) + '…' : '(empty)'));
        log('3d. code=' + (code ? code.slice(0, 12) + '…' : '(empty)'));

        if (!access_token && !code) {
          log('4. FAIL: no tokens in URL');
          window.location.replace('/login?error=invalid');
          return;
        }

        log('5. POST /api/login/finish …');
        const r = await fetch('/api/login/finish', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ access_token, refresh_token, code, next }),
        });
        const j = await r.json();
        log('6. finish status=' + r.status + ' body=' + JSON.stringify(j));

        if (j.ok) {
          log('7. OK — redirecting to ' + (j.next || next));
          window.location.replace(j.next || next);
          return;
        }
        log('7. FAIL — finish said: ' + j.message);
        window.location.replace('/login?error=' + encodeURIComponent(j.message || 'finish_failed'));
      } catch (e) {
        log('EXCEPTION: ' + String(e));
        window.location.replace('/login?error=' + encodeURIComponent(String(e)));
      }
    })();
  </script>
</Layout>
